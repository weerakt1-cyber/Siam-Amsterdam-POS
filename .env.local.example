# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (secret — server-side only)

# ─── Printer / Cash Drawer (optional) ─────────────────────────────────────────
# For network printer. Leave empty if using Bluetooth printer via Android APK.
PRINTER_HOST=
PRINTER_PORT=9100

# ─── Google Sheets Export (optional) ──────────────────────────────────────────
GOOGLE_SHEETS_SERVICE_ACCOUNT=
GOOGLE_SHEET_ID=

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
# 1. Create bot via @BotFather → /newbot
# 2. Send a message to your bot
# 3. Call https://api.telegram.org/bot<TOKEN>/getUpdates to find your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
